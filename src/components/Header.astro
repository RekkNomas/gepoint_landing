<header id="site-header" class="site-header">
  <div class="mx-auto flex h-16 w-full max-w-7xl items-center justify-between px-5 lg:px-8">
      <a href="#inicio" class="transition-opacity hover:opacity-85" aria-label="GP Cloud Solution Inicio">
        <img src="/assets/getpoint/logo-light.png" alt="GP Cloud Solution" width="1646" height="659" class="h-10 w-auto object-contain md:h-11" />
      </a>

    <nav aria-label="Navegación principal" class="hidden lg:block">
      <ul class="flex items-center gap-8 text-sm font-medium text-white/90">
        <li><a href="#inicio" class="nav-link">Inicio</a></li>
        <li><a href="#funcionalidades" class="nav-link">Funcionalidades</a></li>
        <li><a href="#beneficios" class="nav-link">Beneficios</a></li>
        <li><a href="#contacto" class="nav-link">Contacto</a></li>
        <li>
          <a href="#contacto" class="header-cta">
            Solicitar demo
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </li>
      </ul>
    </nav>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" type="button" class="flex h-12 w-12 items-center justify-center rounded-full border border-white/15 text-white/90 transition hover:bg-white/10 lg:hidden" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
      <svg id="icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/></svg>
      <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav id="mobile-menu" aria-label="Navegación móvil" class="mobile-menu hidden">
    <ul class="flex flex-col gap-1 px-5 pb-5 pt-2">
      <li><a href="#inicio" class="mobile-nav-link">Inicio</a></li>
      <li><a href="#funcionalidades" class="mobile-nav-link">Funcionalidades</a></li>
      <li><a href="#beneficios" class="mobile-nav-link">Beneficios</a></li>
      <li><a href="#contacto" class="mobile-nav-link">Contacto</a></li>
      <li class="mt-2">
        <a href="#contacto" class="header-cta inline-flex w-full justify-center">
          Solicitar demo
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });

  // Close menu on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
