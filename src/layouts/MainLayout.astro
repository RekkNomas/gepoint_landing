---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'GP Cloud Solution España | WMS para gestión de almacenes',
  description =
    'Software WMS para empresas en España. Gestiona recepción, inventario, almacenamiento, picking y despacho con trazabilidad en tiempo real.',
} = Astro.props;

const pageUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const ogImage = '/assets/getpoint/logistico-hero-1.jpg';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="SolucionAI" />
    <meta name="publisher" content="SolucionAI" />
    <meta name="theme-color" content="#000000" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={pageUrl} />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'GP Cloud Solution',
      url: 'https://www.gpsolution.es',
      logo: 'https://www.gpsolution.es/assets/getpoint/logo-correct.webp',
      email: 'info@gpsolution.es',
      sameAs: ['https://www.linkedin.com']
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'GP Cloud Solution',
      url: 'https://www.gpsolution.es'
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;800&display=swap" rel="stylesheet" />

    <!-- Preloads -->
    <link rel="preload" as="image" href="/assets/getpoint/wms-mockup.webp" />
    <link rel="preload" as="image" href="/assets/getpoint/logo-correct.webp" />
    <link rel="icon" type="image/png" href="/assets/getpoint/logo-dark.png" />
    <title>{title}</title>
  </head>
  <body class="bg-brand-surface text-brand-ink antialiased">
    <slot />

    <!-- Scroll-triggered reveal animations -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
